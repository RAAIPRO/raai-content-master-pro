# Контент-мастер PRO — опциональные переменные окружения
#
# Без этого файла работают все 10 режимов коробки (только на промпте).
# Заполните только если хотите интеграции с внешними системами:
#  - автопостинг через Telegram-бота
#  - подключение данных из таблиц Google Sheets
#  - email-рассылки через внешний ESP
#
# Как использовать:
#  cp .env.example .env
#  # откройте .env и заполните нужные ключи
#
# Удалите или закомментируйте неиспользуемые строки.

# ═══════════════════════════════════════════════════
# Telegram — публикация и уведомления
# ═══════════════════════════════════════════════════
# Где брать бот-токен: @BotFather в Telegram → /newbot
# Где брать chat_id: @userinfobot → переслать боту любое сообщение

TELEGRAM_BOT_TOKEN=""            # токен вашего бота (опционально)
TELEGRAM_CHAT_ID=""             # ваш chat_id или chat_id канала
TELEGRAM_CHANNEL_ID=""           # ID канала для автопостинга (если нужно)

# ═══════════════════════════════════════════════════
# Google Sheets — контент-план и аналитика
# ═══════════════════════════════════════════════════
# Где брать: https://console.cloud.google.com/ → Service Account → JSON key
# Гайд: docs/onboarding.md раздел "Google Sheets"

GOOGLE_SHEETS_CREDENTIALS_JSON=""      # путь к JSON-ключу сервис-аккаунта
GOOGLE_SHEETS_SPREADSHEET_ID=""       # ID таблицы (из URL)
GOOGLE_SHEETS_TAB_CONTENT_PLAN="ContentPlan" # вкладка контент-плана
GOOGLE_SHEETS_TAB_METRICS="Metrics"      # вкладка с метриками

# ═══════════════════════════════════════════════════
# Email-рассылки (ESP интеграция)
# ═══════════════════════════════════════════════════
# Используется для режима 10 (Email-цепочки) если хотите
# отправку из коробки через API вашего ESP

GETRESPONSE_API_KEY=""           # GetResponse API (если используете)
MAILCHIMP_API_KEY=""            # Mailchimp API (если используете)
UNISENDER_API_KEY=""            # Unisender API (если используете)

# ═══════════════════════════════════════════════════
# Модель LLM (если работает вне Claude/OpenClaw)
# ═══════════════════════════════════════════════════

ANTHROPIC_API_KEY=""            # если запускаете через Anthropic SDK
OPENAI_API_KEY=""              # если через OpenAI-совместимый API

# ═══════════════════════════════════════════════════
# SEO и аналитика (опционально)
# ═══════════════════════════════════════════════════

EXA_API_KEY=""               # Exa.ai для поиска конкурентов
TAVILY_API_KEY=""              # Tavily (альтернатива для поиска)
